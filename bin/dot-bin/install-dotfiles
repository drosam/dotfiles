#!/usr/bin/env bash
set -euo pipefail

repo_dir="${DOTFILES_DIR:-$HOME/Developer/dotfiles}"
cd "$repo_dir"

# ~/.zshrc is commonly created by oh-my-zsh. Remove it so stow can own the link.
rm -f "$HOME/.zshrc"

# Docker/dev containers do not need GUI app config.
if [ -f /.dockerenv ]; then
  folders=(
    "delta"
    "gitconfig"
    "nvim"
    "tmux.conf"
    "tmux"
    "tmuxinator"
    "zshrc"
    "bin"
    "starship"
    "opencode"
    "lazygit"
    "pi"
    "skills"
  )
else
  folders=(
    "alacritty"
    "ghostty"
    "delta"
    "gitconfig"
    "nvim"
    "skhd"
    "tmux.conf"
    "tmux"
    "tmuxinator"
    "zshrc"
    "bin"
    "starship"
    "opencode"
    "lazygit"
    "pi"
    "skills"
  )
fi

stow --dotfiles -t "$HOME" "${folders[@]}"
