{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-openai-codex-auth@latest"
  ],
  "model": "anthropic/claude-sonnet-4-5",
  "autoupdate": false,
  "formatter": false,
  "permission": {
     "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git push *": "deny",
      "git branch -d *": "deny",
      "git branch -D *": "deny",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "pwd*": "allow",
      "bundle exec rspec *": "allow",
      "bin/rspec *": "allow",
      "bundle exec cucumber *": "allow",
      "bin/cucumber *": "allow",
      "BROWSER=headless_chrome bundle exec cucumber *": "allow",
      "BROWSER=headless_chrome bin/cucumber *": "allow",
      "pnpm test *": "allow",
      "pnpm run eslint *": "allow",
      "rm *": "deny",
      "sudo *": "deny"
    },
    "glob": "allow",
    "edit": "ask",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow"
  },
  "experimental": {
    "disable_paste_summary": true,
  }
}

